# Normalize line endings for cross-platform clones
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.snk binary

# Solution and project files
*.sln text eol=crlf
*.csproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Source code
*.cs text diff=csharp
*.json text
*.md text
*.yml text
*.yaml text
Dockerfile text
