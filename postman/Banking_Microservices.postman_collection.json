				{
					"name": "Account Operations",
					"item": [
						{
							"name": "Deposit Money",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 200) {",
											"    const response = pm.response.json();",
											"    if (response.success && response.data && response.data.id) {",
											"        pm.environment.set('accountId', response.data.id);",
											"        console.log('Account ID saved:', response.data.id);",
											"        console.log('New balance:', response.data.balance);",
											"    }",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 1000.00\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/gateway/accounts/deposit",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"accounts",
										"deposit"
									]
								},
								"description": "Deposits money into a customer's account. Validates customer existence before processing."
							},
							"response": []
						},
						{
							"name": "Withdraw Money",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 250.00\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/gateway/accounts/withdraw",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"accounts",
										"withdraw"
									]
								},
								"description": "Withdraws money from a customer's account. Validates sufficient balance before processing."
							},
							"response": []
						},
						{
							"name": "Get Account Details",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/gateway/accounts/{{accountId}}",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"accounts",
										"{{accountId}}"
									]
								},
								"description": "Retrieves account details including customer information."
							},
							"response": []
						},
						{
							"name": "Create Account (Manual)",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"customerId\": \"{{customerId}}\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/gateway/accounts",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"accounts"
									]
								},
								"description": "Manually creates an account for a customer. Usually done automatically when creating a customer."
							},
							"response": []
						}
					]
				}
			],
			"description": "All banking operations through the API Gateway (Ocelot). This is the recommended way to access the microservices."
