{
	"info": {
		"_postman_id": "banking-microservices-api",
		"name": "Banking Microservices API",
		"description": "Complete API collection for Banking Microservices with .NET Core, Ocelot API Gateway, and Service Discovery.\n\n**Quick Start:**\n1. Import this collection\n2. Import the environment file\n3. Start with 'Create Customer' to get a customer ID\n4. Use the customer ID for account operations\n\n**Services:**\n- API Gateway (Ocelot): Port 5010\n- Service Discovery: Port 5003 (with Dashboard)\n- Customer Management: Port 5001\n- Account Management: Port 5002\n- Configuration Service: Port 5004",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "banking-microservices"
	},
	"item": [
		{
			"name": "API Gateway (Recommended)",
			"item": [
				{
					"name": "Customer Operations",
					"item": [
						{
							"name": "Create Customer",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 201) {",
											"    const response = pm.response.json();",
											"    if (response.success && response.data && response.data.id) {",
											"        pm.environment.set('customerId', response.data.id);",
											"        console.log('Customer ID saved:', response.data.id);",
											"    }",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@bankingcorp.com\",\n  \"phone\": \"+1-555-0123\",\n  \"address\": \"123 Banking Street, Finance City, FC 12345\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/gateway/customers",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"customers"
									]
								},
								"description": "Creates a new customer and automatically creates a checking account with balance 0."
							},
							"response": []
						},
						{
							"name": "Get All Customers",
							"request": {
								"method": "GET",
								"header": [],
