							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/gateway/customers/{{customerId}}",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"customers",
										"{{customerId}}"
									]
								},
								"description": "Retrieves a specific customer by their ID."
							},
							"response": []
						},
