								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john.smith@bankingcorp.com\",\n  \"phone\": \"+1-555-0124\",\n  \"address\": \"456 Updated Avenue, New City, NC 54321\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/gateway/customers/{{customerId}}",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"gateway",
										"customers",
										"{{customerId}}"
									]
								},
								"description": "Updates an existing customer's information."
							},
							"response": []
						},
