			}
		},
		{
			"name": "6. Update Customer Info",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Customer updated successfully', function () {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"});",
							"",
							"pm.test('Customer name updated', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.name).to.equal('Alice Updated');",
