							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/gateway/accounts/{{accountId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"gateway",
						"accounts",
						"{{accountId}}"
					]
				}
			}
		},
