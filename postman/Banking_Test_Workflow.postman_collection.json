					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Account retrieved successfully', function () {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"});",
							"",
							"pm.test('Balance is $500', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.balance).to.equal(500);",
							"    console.log('Current balance: $' + response.data.balance);",
							"});",
							"",
							"pm.test('Customer info included', function () {",
							"    const response = pm.response.json();",
