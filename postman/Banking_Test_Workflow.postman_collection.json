					"path": [
						"gateway",
						"customers",
						"{{customerId}}"
					]
				}
			}
		},
		{
			"name": "7. Test Insufficient Balance",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Insufficient balance error returned', function () {",
							"    pm.expect(pm.response.code).to.equal(400);",
							"});",
							"",
							"pm.test('Error message is appropriate', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.title).to.include('Insufficient Balance');",
							"    console.log('Insufficient balance properly handled');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 1000.00\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/gateway/accounts/withdraw",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"gateway",
						"accounts",
						"withdraw"
					]
				}
			}
		},
		{
			"name": "8. Cleanup - Delete Customer",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Customer deleted successfully', function () {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"});",
							"",
							"pm.test('Deletion message correct', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.message).to.include('deleted');",
							"    console.log('Test cleanup completed - Customer and account deleted');",
							"});",
							"",
							"// Clear environment variables",
							"pm.environment.unset('customerId');",
							"pm.environment.unset('accountId');",
							"console.log('Environment variables cleared');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/gateway/customers/{{customerId}}",
