				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.info.iteration === (pm.info.iterationCount - 1)) {",
					"    console.log('Banking Test Workflow Completed!');",
					"}"
				]
			}
		}
	]
