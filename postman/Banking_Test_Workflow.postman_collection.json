{
	"info": {
		"_postman_id": "banking-test-workflow",
		"name": "Banking Test Workflow",
		"description": "**Automated test workflow for Banking Microservices**\n\nThis collection demonstrates the complete banking workflow:\n1. Create Customer (auto-saves customer ID)\n2. Deposit Money (auto-saves account ID)\n3. Check Balance\n4. Withdraw Money\n5. Verify Final Balance\n6. Update Customer Info\n7. Cleanup (Delete Customer)\n\n**Run Instructions:**\n1. Import main collection and environment\n2. Run this workflow collection with 'Collection Runner'\n3. All tests will pass if services are working correctly\n\n**Prerequisites:**\n- All 5 microservices running\n- Service Discovery showing all services healthy",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Create Test Customer",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Customer created successfully', function () {",
							"    pm.expect(pm.response.code).to.equal(201);",
							"});",
							"",
							"pm.test('Response has success=true', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.success).to.be.true;",
							"});",
							"",
							"pm.test('Customer ID is generated', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.id).to.exist;",
							"    pm.environment.set('customerId', response.data.id);",
							"    console.log('Customer created with ID:', response.data.id);",
							"});",
							"",
							"pm.test('Customer data is correct', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.name).to.equal('Alice Test');",
							"    pm.expect(response.data.email).to.equal('alice.test@bankingcorp.com');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Alice Test\",\n  \"email\": \"alice.test@bankingcorp.com\",\n  \"phone\": \"+1-555-TEST\",\n  \"address\": \"123 Test Street, Test City, TC 12345\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/gateway/customers",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"gateway",
						"customers"
					]
				}
			}
		},
		{
			"name": "2. Initial Deposit",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Deposit successful', function () {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"});",
							"",
							"pm.test('Balance updated correctly', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.balance).to.equal(500);",
							"    pm.environment.set('accountId', response.data.id);",
							"    console.log('Deposited $500, Account ID:', response.data.id);",
							"});",
							"",
							"pm.test('Account type is Checking', function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.data.accountType).to.equal('Checking');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"amount\": 500.00\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/gateway/accounts/deposit",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"gateway",
						"accounts",
						"deposit"
					]
				}
			}
		},
